{
  "name": "@bemedev/typings",
  "version": "0.1.0",
  "description": "Typings by variables",
  "author": {
    "email": "bri_lvi@icloud.com",
    "name": "chlbri",
    "url": "https://bemedev.vercel.app"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chlbri/typings.git"
  },
  "license": "MIT",
  "type": "module",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "module": "lib/index.js",
  "maintainers": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "contributors": [
    {
      "email": "bri_lvi@icloud.com",
      "name": "chlbri",
      "url": "https://bemedev.vercel.app"
    }
  ],
  "keywords": [
    "typings",
    "typescript",
    "types"
  ],
  "files": [
    "lib",
    "public"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm rm:lib && pnpm run rolldown",
    "ci": "CI_START=$(date +%s) && pnpm run config:off && pnpm run lint && pnpm run test && pnpm run p-q && echo \"\n✅ CI takes $(($(date +%s) - CI_START))s\n\"",
    "ci:admin": "pnpm run rm && pnpm run upgrade:fast && pnpm run ci",
    "clean": "pnpm run rm && pnpm run config",
    "config": "pnpm install",
    "config:off": "pnpm run config --offline",
    "config:vitest": "pnpm add -D @vitest/coverage-v8@3.2.4 @vitest/ui@3.2.4 vitest@3.2.4",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "pnpm run fmt && pnpm run lint:fix",
    "lint:fix": "oxlint --fix",
    "lint:watch": "onchange --await-write-finish 1500 -d 10000 -v \"**/*.ts\" -- pnpm run lint",
    "prepublishOnly": "",
    "prepare": "husky",
    "pretest": "pnpm run build && pnpm run size",
    "posttest": "pnpm run fmt",
    "prettier": "prettier --write \"src/**/*.{ts,tsx}\"",
    "p-q": "pretty-quick",
    "rinit": "pnpm run rm && pnpm run config",
    "rinit:off": "pnpm run rm && pnpm run config:off",
    "rimraf": "pnpx rimraf -rf",
    "rm": "pnpm run rimraf -- node_modules pnpm-lock.yaml",
    "rm:lib": "pnpm run rimraf -- lib",
    "rolldown": "rolldown -c",
    "size": "size-limit",
    "test": "pnpm run test:coverage",
    "test:coverage": "vitest run",
    "test:only": "pnpm run test:coverage --no-coverage",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "upgrade": "pnpm dlx @bemedev/upgrade-npm-package && pnpm run config:vitest",
    "upgrade:fast": "pnpm up --latest && pnpm run config:vitest"
  },
  "size-limit": [
    {
      "path": "lib/*.js",
      "limit": "10 KB"
    },
    {
      "path": "lib/*.cjs",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@bemedev/dev-utils": "^0.5.2",
    "@bemedev/fsf": "^1.0.1",
    "@size-limit/file": "^12.0.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "3.2.4",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "onchange": "^7.1.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "pretty-quick": "^4.2.2",
    "rolldown": "1.0.0-rc.13",
    "size-limit": "^12.0.1",
    "tslib": "^2.8.1",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
